{
	"chapterEn": "Chapter 2",
	"chapterAs": "ܩܦܠܐܘܢ: ܓ.",
	"verses": [
		{
			"verseNumberEn": "1",
			"verseNumberAs": "ܐ",
			"verseText": "ܘܚܘܼܘܹܐ ܝܲܕܘܼܥܵܐ ܗ݇ܘܵܐ ܡܼܢ ܟܠ ܚܲܝܘܬܵܐ ܕܕܸܫܬܵܐ ܕܥܒܸܕܠܹܐ ܡܵܪܝܵܐ ܐܲܠܵܗܵܐ. ܘܐ݇ܡܸܪܹܐ ܠܒܲܟܼܬܵܐ: ܡܸܓ̰ܸܕ ܝܼܠܵܐ ܕܐ݇ܡܸܪܹܐ ܐܲܠܵܗܵܐ: ܠܵܐ ܐܟܼܠܝܼܬܘܿܢ ܡܼܢ ܟܠ ܐܝܼܠܵܢܵܐ ܕܓܲܢܬܵܐ؟",
			"verseNotes": []
		},
		{
			"verseNumberEn": "2",
			"verseNumberAs": "ܒ",
			"verseText": "ܘܐ݇ܡܸܪܵܐ ܒܲܟܼܬܵܐ ܠܚܘܼܘܹܐ: ܡܼܢ ܛܥܘܼܢܬܵܐ ܕܝܼܠܵܢܹ̈ܐ ܕܓܲܢܬܵܐ ܒܸܬ ܐܵܟܼܠܵܟ:",
			"verseNotes": []
		},
		{
			"verseNumberEn": "3",
			"verseNumberAs": "ܓ",
			"verseText": "ܘܡܼܢ ܛܥܘܼܢܬܵܐ ܕܐܝܼܠܵܢܵܐ ܕܒܦܹܦܲܠܓܵܐ ܕܓܲܢܬܵܐ ܐ݇ܡܸܪܹܐ ܐܲܠܵܗܵܐ: ܠܵܐ ܐܟܼܠܝܼܬܘܿܢ ܡܸܢܹܗ: ܘܠܵܐ ܕܵܩܪܝܼܬܘܿܢ ܒܝܹܗ: ܠܵܐ ܗ݇ܘܹܐ ܕܡܵܝܬܝܼܬܘܿܢ.",
			"verseNotes": []
		},
		{
			"verseNumberEn": "4",
			"verseNumberAs": "ܕ",
			"verseText": "ܘܐ݇ܡܸܪܹܐ ܚܘܼܘܹܐ ܠܒܲܟܼܬܵܐ: ܡܝܵܬܵܐ ܠܹܐ ܡܵܝܬܝܼܬܘܿܢ:",
			"verseNotes": []
		},
		{
			"verseNumberEn": "5",
			"verseNumberAs": "ܗ",
			"verseText": "ܣܵܒܵܒܿ ܕܒܝܼܕܲܥܝܵܐ ܝ݇ܠܹܐ ܐܲܠܵܗܵܐ ܕܒܝܼܘܿܡܵܐ ܕܐܵܟܼܠܝܼܬܘܿܢ ܡܸܢܹܗ: ܒܸܬ ܦܵܝܫܝܼ ܦܬܝܼܚܹܐ ܥܲܝܢܵܘ̈ܟܼܘܿܢ: ܘܒܸܬ ܗܵܘܝܼܬܘܿܢ ܐܲܝܟ ܐܲܠܵܗܹ̈ܐ: ܝܲܕܥܵܢܹ̈ܐ ܕܛܵܒܼܬܵܐ ܘܒܝܼܫܬܵܐ.",
			"verseNotes": []
		},
		{
			"verseNumberEn": "6",
			"verseNumberAs": "ܘ",
			"verseText": "ܘܚܙܹܠܵܐ ܒܲܟܼܬܵܐ ܕܨܦܵܝܼ ܗ݇ܘܵܐ ܐܝܼܠܵܢܵܐ ܩܵܐ ܐ݇ܟܼܵܠܵܐ: ܘܕܡܲܒܿܣܸܡܵܢܵܐ ܗ݇ܘܵܐ ܠܥܲܝܢܹ̈ܐ: ܘܫܘܼܘܸܬܵܐ ܐܝܼܠܵܢܵܐ ܠܥܲܩܠܘܼܢܹܐ: ܘܫܩܸܠܵܐ ܡܼܢ ܛܥܘܼܢܬܘܼܗܝ ܘܐ݇ܟܸܠܵܐ: ܘܝܸܗ݇ܒܸܠܵܐ ܐܘܼܦ ܠܓܲܒܼܪܘܼܗܿ ܥܲܡܘܼܗܿ: ܘܐ݇ܟܸܠܹܐ.",
			"verseNotes": []
		},
		{
			"verseNumberEn": "7",
			"verseNumberAs": "ܙ",
			"verseText": "ܘܦܸܫܠܘܿܢ ܦܬܝܼܚܹܐ ܥܲܝܢܹ̈ܐ ܕܬܸܪܘܵܝ: ܘܝ݇ܕܸܥܠܘܿܢ ܕܫܘܼܠܚܵܝܹ̈ܐ ܗ݇ܘܵܐ: ܘܚܸܛܠܘܿܢ ܒܥܘܼܕܵܠܹܐ ܛܲܪܦܹ̈ܐ ܕܬܹܐܢܵܐ:",
			"verseNotes": []
