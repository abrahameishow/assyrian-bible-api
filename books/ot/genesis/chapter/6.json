{
	"chapterEn": "Chapter 6",
	"chapterAs": "ܩܦܠܐܘܢ: ܘ.",
	"verses": [
		{
			"verseNumberEn": "1",
			"verseNumberAs": "ܐ",
			"verseText": "ܘܗ݇ܘܹܠܵܐ ܟܲܕ ܫܘܼܪܹܠܹܐ ܒܲܪܢܵܫܵܐ ܠܸܙܝܵܕܵܐ ܥܲܠ ܦܵܬܵܐ ܕܐܲܪܥܵܐ: ܘܒܢܵܬܹ̈ܐ ܦܸܫܠܘܿܢ ܝ݇ܠܝܼܕܹܐ ܐܸܠܵܝ:",
			"verseNotes": []
		},
		{
			"verseNumberEn": "2",
			"verseNumberAs": "ܒ",
			"verseText": "ܘܚܙܹܠܘܿܢ ܒܢܘܼܢܹ̈ܐ ܕܐܲܠܵܗܵܐ ܠܒܢܵܬܹ̈ܐ ܕܒܲܪܢܵܫܵܐ ܕܫܵܦܝܼܪܹ̈ܐ ܗ݇ܘܵܘ: ܫܩܸܠܘܿܢ ܐܸܠܵܝ ܒܲܟܼܬܵܬܹ̈ܐ ܡܼܢ ܟܠ ܕܓܘܼܒܹܠܘܿܢ.",
			"verseNotes": []
		},
		{
			"verseNumberEn": "3",
			"verseNumberAs": "ܓ",
			"verseText": "ܘܐ݇ܡܸܪܹܐ ܡܵܪܝܵܐ: ܠܹܐ ܗܵܟܿܡܵܐ ܪܘܼܚܼܝܼ ܒܒܲܪܢܵܫܵܐ ܠܥܵܠܲܡ: ܣܵܒܵܒܿ ܕܗܿܘ ܒܸܣܪܵܐ ܝ݇ܠܹܐ: ܘܒܸܬ ܗܵܘܝܼ ܝܘܿܡܵܢܘܼ̈ܗܝ: ܡܵܐܐ ܘܥܸܣܪܝܼ ܫܸܢܹ̈ܐ.",
			"verseNotes": [{ "verseNote": "ܗܵܟܿܡܵܐ: ܝܢ ܥܵܡܪܵܐ" }]
		},
		{
			"verseNumberEn": "4",
			"verseNumberAs": "ܕ",
			"verseText": "ܢܦ̮ܝܼܠܝܼ̈ܡ ܐܝܼܬ ܗ݇ܘܵܐ ܒܐܲܪܥܵܐ ܒܐܵܢܝܼ ܝܘܿܡܵܢܹ̈ܐ. ܘܐܘܼܦ ܒܵܬ݇ܪ ܗܵܕܵܐ: ܟܲܕ ܐ݇ܘܸܪܘܿܢ ܒܢܘܼܢܹ̈ܐ ܕܐܲܠܵܗܵܐ ܠܒܢܵܬܹ̈ܐ ܕܒܲܪܢܵܫܵܐ: ܝ݇ܠܸܕܠܘܿܢ ܩܵܬܵܝ. ܐܵܢܝܼ ܗ݇ܘܵܐ ܓܲܢ݇ܒܵܪܹ̈ܐ ܕܡܼܢ ܥܵܠܲܡ: ܐ݇ܢܵܫܹ̈ܐ ܕܫܸܡܵܐ.",
			"verseNotes": [{ "verseNote": "ܢܦ̮ܝܼܠܝܼ̈ܡ: ܝܥܢܐ ܓܲܢ݇ܒܵܪܹ̈ܐ" }]
		},
		{
			"verseNumberEn": "5",
			"verseNumberAs": "ܗ",
			"verseText": "ܘܚܙܹܠܹܐ ܡܵܪܝܵܐ ܕܙܸܕܠܵܐ ܒܝܼܫܬܵܐ ܕܒܲܪܢܵܫܵܐ ܒܐܲܪܥܵܐ: ܘܟܿܠ ܝܲܨܪܵܐ ܕܚܘܼܫܵܒܹ̈ܐ ܕܠܸܒܘܼܗܝ ܗܲܪ ܒܝܼܫܬܵܐ ܟܠܝܘܿܡ.",
			"verseNotes": []
		},
