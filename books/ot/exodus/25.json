{
	"chapterEn": "Chapter 25",
	"chapterAs": "ܩܦܠܐܘܢ: ܟܗ.",
	"verses": [
		{
			"verseNumberEn": "1",
			"verseNumberAs": "ܐ",
			"verseText": "ܘܗܘܼܡܙܸܡܠܹܐ ܡܵܪܝܵܐ ܥܲܡ ܡܘܼܫܹܐ: ܒܹܐܡܵܪܵܐ:"
		},
		{
			"verseNumberEn": "2",
			"verseNumberAs": "ܒ",
			"verseText": "ܗܲܡܙܸܡ ܥܲܡ ܒܢܲܝ̈ ܝܼܣܪܵܝܹܠ: ܘܫܵܩܠܝܼ ܩܵܬܝܼ ܦܘܼܪܫܵܢܵܐ ܕܡܵܪܲܡܬܵܐ. ܡ̣ܢ ܟܠ ܐ݇ܢܵܫܵܐ ܕܥܵܒܸܕ ܠܹܗ ܪܵܙܝܼ ܠܸܒܘܼܗܝ: ܫܵܩܠܝܼܬܘܿܢ ܦܘܼܪܫܵܢܝܼ ܕܡܵܪܲܡܬܵܐ."
		},
		{
			"verseNumberEn": "3",
			"verseNumberAs": "ܓ",
			"verseText": "ܘܐܵܗܵܐ ܝ݇ܠܹܐ ܦܘܼܪܫܵܢܵܐ ܕܡܵܪܲܡܬܵܐ ܕܫܵܩܠܝܼܬܘܿܢ ܡܸܢܵܝ: ܕܲܗܒ̣ܵܐ: ܘܣܹܐܡܵܐ: ܘܢܚܵܫܵܐ:"
		},
		{
			"verseNumberEn": "4",
			"verseNumberAs": "ܕ",
			"verseText": "ܘܡܝܼܠܵܐ: ܘܐܲܪܓܘܵܢܵܐ: ܘܩܸܪܡܝܼܙ: ܘܟܸܬܵ‍ܢ ܢܵܙܸܟ: ܘܣܲܥܪܵܐ ܕܥܸܙܹ̈ܐ."
		},
		{
			"verseNumberEn": "5",
			"verseNumberAs": "ܗ",
			"verseText": "ܘܓܸܠܕܹ̈ܐ ܕܒܲܪ̈ܥܵܢܹܐ ܡܘܼܣܡܸܩܹ̈ܐ: ܘܓܸܠ̈ܕܹܐ ܕܬܲܚܫܹ̈ܐ: ܘܩܲܝܣܹ̈ܐ ܕܫܸܛܝܼܡ:"
		},
		{
			"verseNumberEn": "6",
			"verseNumberAs": "ܘ",
			"verseText": "ܡܸܫܚܵܐ ܩܵܐ ܩܲܢܕܝܼܠܵܐ: ܐܲܕܘܹ̈ܐ ܩܵܐ ܡܸܫܚܵܐ ܕܡܫܵܚܬܵܐ: ܘܩܵܐ ܒܸܣܡܵܐ ܪܹܝܚܵܢܵܐ."
		},
		{
			"verseNumberEn": "7",
			"verseNumberAs": "ܙ",
			"verseText": "ܟܹܐܦܹ̈ܐ ܕܫܘܼܗܲܡ: ܘܟܹܐܦܹ̈ܐ ܕܦܵܝܫܝܼ ܡܘܼܠܚܸܡܹܐ ܩܵܐ ܐܸܦܘܿܕܵܐ ܘܩܵܐ ܒܪܵܬ݇ ܨܲܕܪܵܐ."
		},
		{
			"verseNumberEn": "8",
			"verseNumberAs": "ܚ",
			"verseText": "ܘܬܵܪܨܝܼ ܩܵܬܝܼ ܡܲܩܕܫܵܐ: ܘܫܵܪܸ‍ܢ ܒܓܵܘܵܝ."
		},
		{
			"verseNumberEn": "9",
			"verseNumberAs": "ܛ",
			"verseText": "ܐܲܝܟ ܟܠ ܕܐܵܢܵܐ ܡܲܚܙܸ‍ܢ ܐܸܠܘܼܟ ܕܡܘܼܬܵܐ ܕܡܵܫܸܟ̇ܢܵܐ: ܘܕܡܘܼܬܵܐ ܕܟ̇ܠܵܝ ܐܲܨܠܵܗܲܬ̈ܘܼܗܝ: ܘܗܲܬܟ̣ܵܐ ܬܵܪܨܝܼܬܘܿܢ."
		},
		{
			"verseNumberEn": "10",
			"verseNumberAs": "ܝ",
			"verseText": "ܘܬܵܪܨܝܼ ܩܹܒ̣ܘܼܬܵܐ ܕܩܲܝܣܹ̈ܐ ܕܫܸܛܝܼܡ: ܬܪܵܝ ܝܲܡܝܼܢܹ̈ܐ ܘܦܲܠܓܹܐ ܝܘܼܪܟ̣ܘܼܬܘܼܗ̇: ܘܝܲܡܝܼܢܵܐ ܘܦܲܠܓܹܐ ܦܸܬܝܘܼܬܘܼܗ̇: ܘܝܲܡܝܼܢܵܐ ܘܦܲܠܓܹܐ ܪܵܡܘܼܬܘܼܗ̇."
		},
