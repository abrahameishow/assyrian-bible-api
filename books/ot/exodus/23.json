{
	"chapterEn": "Chapter 23",
	"chapterAs": "ܩܦܠܐܘܢ: ܟܓ.",
	"verses": [
		{
			"verseNumberEn": "1",
			"verseNumberAs": "ܐ",
			"verseText": "ܠܵܐ ܡܵܪܡܸܬ ܒܵܗܣ ܕܵܓܵܠܬܵܐ. ܠܵܐ ܡܲܬܒܸܬ ܐܝܼܕܘܼܟ ܥܲܡ ܒܝܼܫܹ̈ܐ ܠܸܗܘܵܝܵܐ ܣܵܗܕܵܐ ܥܵܘܵܠܵܐ."
		},
		{
			"verseNumberEn": "2",
			"verseNumberAs": "ܒ",
			"verseText": "ܠܵܐ ܗܵܘܸܬ ܒܵܬ݇ܪ ܣܲܓܝܼ̈ܐܹܐ ܠܸܥܒ̣ܵܕܵܐ ܒܝܼܫܬܵܐ: ܘܠܵܐ ܓ̰ܼܿܘܸܒܸܬ ܥܲܠ ܡܲܩܲܪܵܨܘܼܬܵܐ ܠܸܩܠܵܒܵܐ ܒܵܬ݇ܪ ܣܲܓܝܼ̈ܐܹܐ ܠܡܲܩܠܘܼܒܹܐ."
		},
		{
			"verseNumberEn": "3",
			"verseNumberAs": "ܓ",
			"verseText": "ܘܠܡܸܣܟܹܢܵܐ ܠܵܐ ܡܲܩܸܡܸܬ ܚܵܨܵܐ ܒܡܲܩܪܲܨܬܘܼܗܝ."
		},
		{
			"verseNumberEn": "4",
			"verseNumberAs": "ܕ",
			"verseText": "ܟܲܕ ܬܵܦܩܸܬ ܒܬܵܘܪܵܐ ܕܕܸܫܡܸܢܘܼܟ: ܝܲܢ ܒܚܡܵܪܘܼܗܝ: ܒܸܚܠܵܛܵܐ: ܡܲܕܘܼܪܹܐ ܡܲܕܸܪܸܬ ܠܹܗ ܐܸܠܹܗ."
		},
		{
			"verseNumberEn": "5",
			"verseNumberAs": "ܗ",
			"verseText": "ܟܲܕ ܚܵܙܸܬ ܚܡܵܪܵܐ ܕܣܵܢܝܵܢܘܼܟ ܒܪܝܼܟܵܐ ܬܚܘܿܬ ܛܲܥܢܘܼܗܝ: ܘܡܲܚܦܘܼܠܹܐ ܝ݇ܘܸܬ ܡ̣ܢ ܠܸܫܪܵܝܘܼܗܝ: ܡܸܫܪܵܝܵܐ ܫܵܪܸܬ ܚܲܒ̣̈ܠܹܐ ܥܲܡܹܗ."
		},
		{
			"verseNumberEn": "6",
			"verseNumberAs": "ܘ",
			"verseText": "ܠܵܐ ܡܲܦܟ̰ܸܠܸܬ ܕܝܼܘܵܢ ܕܡܸܣܟܹܢܘܼܟ ܒܡܲܩܪܲܨܬܘܼܗܝ."
		},
		{
			"verseNumberEn": "7",
			"verseNumberAs": "ܙ",
			"verseText": "ܡ̣ܢ ܫܘܼܠܵܐ ܕܘܼܓܠܵܢܵܐ ܗܵܘܸܬ ܪܸܚܩܵܐ: ܘܙܲܟܵܝܵܐ ܘܙܲܕܝܼܩܵܐ ܠܵܐ ܩܵܛܠܸܬ: ܣܵܒܵܒ̇ ܕܠܹܐ ܡܲܟ̇ܫܸܛܸܢ ܠܒܝܼܫܵܐ."
		},
		{
			"verseNumberEn": "8",
			"verseNumberAs": "ܚ",
			"verseText": "ܘܪܸܫܘܲܬ ܠܵܐ ܫܵܩܠܸܬ: ܣܵܒܵܒ̇ ܕܪܸܫܘܲܬ ܟܹܐ ܡܲܣܡܝܼܵܐ ܠܚܵܙܝܵܢܹ̈ܐ: ܘܟܹܐ ܡܲܓ̰ܪܸܛܵܐ ܠܗܹܡܸܙܡܵܢܹ̈ܐ ܕܙܲܕܝܼܩܹ̈ܐ."
		},
		{
			"verseNumberEn": "9",
			"verseNumberAs": "ܛ",
			"verseText": "ܘܠܡܵܫܵܚܲܛܹ̈ܐ ܠܵܐ ܡܲܥܝܸܩܸܬ: ܘܐܲܚܬܘܿܢ ܟܹܐ ܝܲܕܥܝܼܬܘܿܢ ܠܓܵܢܵܐ ܕܡܵܫܵܚܲܛ: ܣܵܒܵܒ̇ ܕܡܵܫܵܚܲܛܹ̈ܐ ܝ݇ܬܘܿܢ ܗ݇ܘܵܘ ܒܐܲܪܥܵܐ ܕܡܸܨܪܹܝܢ."
		},
		{
			"verseNumberEn": "10",
			"verseNumberAs": "ܝ",
			"verseText": "ܘܐܸܫܬܵܐ ܫܸܢܹ̈ܐ ܙܲܪܥܸܬ ܐܲܪܥܘܼܟ: ܘܓ̰ܼܿܡܥܸܬ ܗܵܨܝܼܠܘܼܗ̇."
		},
		{
			"verseNumberEn": "11",
			"verseNumberAs": "ܝܐ",
			"verseText": "ܘܫܹܢ݇ܬܵܐ ܕܫܲܒܲܥ: ܗ̇ܝ ܒ̇ܛܸܠܸܬ ܠܵܗ̇ ܘܫܵܒ̣ܩܸܬ ܠܵܗ̇: ܘܐܵܟ̣ܠܝܼ ܡܸܣܟܹܢܹ̈ܐ ܕܛܵܝܸܦܘܼܟ: ܘܙܝܼܘܼܕܵܝ ܐܵܟ̣ܠܵܐ ܗܲܝܘܵܢ ܕܕܸܫܬܵܐ: ܗܲܬܟ̣ܵܐ ܥܵܒ̣ܕܸܬ ܠܟܲܪܡܘܼܟ: ܠܙܲܝܬܘܼܟ."
		},
