{
	"chapterEn": "Chapter 15",
	"chapterAs": "ܩܦܠܐܘܢ: ܝܗ.",
	"verses": [
		{
			"verseNumberEn": "1",
			"verseNumberAs": "ܐ",
			"verseText": "ܐܲܝܓܵܐ ܙܡܸܪܹܐ ܡܘܼܫܹܐ ܘܒܢܲܝ̈ ܝܼܣܪܵܝܹܠ ܐܵܗܵܐ ܙܡܵܪܬܵܐ ܠܡܵܪܝܵܐ: ܘܐ݇ܡܸܪܘܿܢ: ܒܹܐܡܵܪܵܐ:\nܒܸܬ ܙܵܡܪܸ‍ܢ ܠܡܵܪܝܵܐ: ܣܵܒܵܒ̇ ܕܡܸܪܝܵܡܵܐ ܪܸܡܠܹܐ:\nܣܘܼܣܹܐ ܘܪܵܟܒ̣ܵܢܘܼܗܝ ܕܪܹܠܹܐ ܒܝܵܡܵܐ."
		},
		{
			"verseNumberEn": "2",
			"verseNumberAs": "ܒ",
			"verseText": "ܚܲܝܠܝܼ ܘܙܡܵܪܬܝܼ ܡܵܪܝܵܐ:\nܘܗ݇ܘܹܠܹܐ ܐܸܠܝܼ ܠܦܘܼܪܩܵܢܵܐ.\nܐܵܗܵܐ ܝ݇ܠܹܐ ܐܲܠܵܗܝܼ: ܘܒܸܬ ܫܵܒ̇ܚܸܢܹܗ:\nܐܲܠܵܗܹܗ ܕܒܵܒ̇ܝܼ: ܘܒܸܬ ܡܵܪܡܸܢܹܗ."
		},
		{
			"verseNumberEn": "3",
			"verseNumberAs": "ܓ",
			"verseText": "ܡܵܪܝܵܐ ܐ݇ܢܵܫܵܐ ܕܦܠܵܫܵܐ ܝ݇ܠܹܐ: ܝܹܗܘܿܘܵܐ ܫܸܡܘܼܗܝ."
		},
		{
			"verseNumberEn": "4",
			"verseNumberAs": "ܕ",
			"verseText": "ܟܵܠܸܣܟܹ̈ܐ ܕܦܸܪܥܘܿܢ ܘܚܲܝܠܘܼܗܝ ܕܪܹܠܹܐ ܒܝܵܡܵܐ: ܘܓܘܼܒ̇ܝܹ̈ܐ ܕܫܵܠܸܫܘܼ̈ܗܝ ܦܸܫܠܘܿܢ ܛܘܼܒܸܥܝܹܐ ܒܝܵܡܵܐ ܕܣܘܿܦ."
		},
		{
			"verseNumberEn": "5",
			"verseNumberAs": "ܗ",
			"verseText": "ܬܗܘܿܡܹ̈ܐ ܟܘܼܣܝܵܝܠܘܿܢ:\nܨܠܹܠܘܿܢ ܠܥܘܼܡܩܹ̈ܐ ܐܲܝܟ ܟܹܐܦܵܐ."
		},
		{
			"verseNumberEn": "6",
			"verseNumberAs": "ܘ",
			"verseText": "ܝܲܡܝܼܢܘܼܟ: ܝܵܐ ܡܵܪܝܵܐ: ܦܸܫܠܵܐ ܫܒ̣ܝܼܚܬܵܐ ܒܚܲܝܠܵܐ. ܝܲܡܝܼܢܘܼܟ: ܝܵܐ ܡܵܪܝܵܐ: ܛܘܼܚܛܸܚܠܵܐ ܕܸܫܡܸܢ."
		},
		{
			"verseNumberEn": "7",
			"verseNumberAs": "ܙ",
			"verseText": "ܘܒܓܘܼܪܘܼܬܵܐ ܕܪܵܡܘܼܬܘܼܟ ܬܠܸܚܠܘܼܟ ܠܩܵܝܡܵܢܹ̈ܐ ܕܲܪܩܘܼܠܘܼܟ:\nܫܘܼܕܸܪܘܼܟ ܚܸܡܬܘܼܟ: ܐ݇ܟ̣ܝܼܠܵܝܠܵܐ ܐܲܝܟ ܟܘܼܠܵܫ."
		},
		{
			"verseNumberEn": "8",
			"verseNumberAs": "ܚ",
			"verseText": "ܘܒܪܘܼܚܵܐ ܕܦܘܼܩܵܩ̈ܘܼܟ ܦܸܫܠܘܿܢ ܡܘܼܟ̇ܠܝ̣ܹܐ ܐܲܝܟ ܪܘܼܡܬܵܐ ܡ̈ܝܼܵܐ:\nܟܠܹܠܘܿܢ ܐܲܝܟ ܩܘܼܚܵܐ ܓ̰ܵܪ̈ܝܵܢܹܐ:\nܩܫܹܠܘܿܢ ܬܗܘܿܡܹ̈ܐ ܒܠܸܒܵܐ ܕܝܵܡܵܐ."
		},
