{
	"chapterEn": "Chapter 26",
	"chapterAs": "ܩܦܠܐܘܢ: ܟܘ.",
	"verses": [
		{
			"verseNumberEn": "1",
			"verseNumberAs": "ܐ",
			"verseText": "ܘܠܡܵܫܸܟ̇ܢܵܐ ܬܵܪܨܸܬ ܒܥܸܣܪܵܐ ܦܲܪ̈ܕܹܐ: ܕܟܸܬܵܢ ܢܵܙܸܟ ܩܡܝܼܛܵܐ: ܘܡܝܼܠܵܐ: ܘܐܲܪܓܘܵܢܵܐ: ܘܩܸܪܡܝܼܙ: ܥܲܡ ܟܪ̈ܘܿܒܹܐ ܦܘܼܠܚܵܢܵܐ ܕܐܘܼܡܵܢܵܐ ܬܵܪܨܸܬ ܠܗ݇ܘܿܢ."
		},
		{
			"verseNumberEn": "2",
			"verseNumberAs": "ܒ",
			"verseText": "ܝܘܼܪܟ̣ܘܼܬܵܐ ܕܚܵܐ ܦܲܪܕܵܐ ܥܸܣܪܝܼ ܘܬܡܵܢܝܵܐ ܝܲܡܝܼܢܹ̈ܐ: ܘܦܸܬܝܘܼܬܵܐ ܐܲܪܒܲܥ ܝܲܡܝܼ̈ܢܹܐ ܕܚܵܐ ܦܲܪܕܵܐ: ܚܵܐ ܟܝܼܘܼܠܵܐ ܠܟ̇ܠܵܝ ܦܲܪ̈ܕܹܐ."
		},
		{
			"verseNumberEn": "3",
			"verseNumberAs": "ܓ",
			"verseText": "ܚܲܡܫܵܐ ܦܲܪ̈ܕܹܐ ܗܵܘܝܼ ܬܪܝܼܩܹܐ ܚܵܐ ܒܗ̇ܘ ܐ݇ܚܹܪ݇ܢܵܐ: ܘܚܲܡܫܵܐ ܦܲܪ̈ܕܹܐ ܬܪܝܼܩܹܐ ܚܵܐ ܒܗ̇ܘ ܐ݇ܚܹܪ݇ܢܵܐ."
		},
		{
			"verseNumberEn": "4",
			"verseNumberAs": "ܕ",
			"verseText": "ܘܬܵܪܨܸܬ ܒܸܠܘܼܩܝܵܬܹ̈ܐ ܕܡܝܼܠܵܐ ܥܲܠ ܣܸܦܬܵܐ ܕܚܵܐ ܦܲܪܕܵܐ ܡ̣ܢ ܡܲܪܙܵܐ ܒܬܪܵܩܬܵܐ: ܘܗܲܬܟ̣ܵܐ ܬܵܪܨܸܬ ܒܣܸܦܬܵܐ ܕܦܲܪܕܵܐ ܕܡܲܪܙܵܐ ܒܬܪܵܩܬܵܐ ܕܗ̇ܘ ܕܬܪܵܝ."
		},
		{
			"verseNumberEn": "5",
			"verseNumberAs": "ܗ",
			"verseText": "ܚܲܡܫܝܼ ܒܸܠܘܼܩܝܵܬܹ̈ܐ ܬܵܪܨܸܬ ܒܚܵܐ ܦܲܪܕܵܐ: ܘܚܲܡܫܝܼ ܒܸܠܘܼܩܝܵܬܹ̈ܐ ܬܵܪܨܸܬ ܒܡܲܪܙܵܐ ܕܦܲܪܕܵܐ ܕܝܼܠܹܐ ܒܬܪܵܩܬܵܐ ܕܗ̇ܘ ܕܬܪܵܝ: ܡܘܼܬܒܹܐ ܠܒܲܪܩܘܼܠ ܒܸܠܘܼܩܝܵܬܹ̈ܐ ܚܵܐ ܠܗ̇ܘ ܐ݇ܚܹܪ݇ܬܵܐ."
		},
		{
			"verseNumberEn": "6",
			"verseNumberAs": "ܘ",
			"verseText": "ܘܬܵܪܨܸܬ ܚܲܡܫܝܼ ܦܸܫܟ̈ܘܼܙܹ̃ܐ ܕܕܲܗܒ̣ܵܐ: ܘܬܵܪܩܸܬ ܦܲܪ̈ܕܹܐ ܚܵܐ ܒܗ̇ܘ ܐ݇ܚܹܪ݇ܢܵܐ ܒܦܸܫܟ̈ܘܼܙܹ̃ܐ. ܘܗܵܘܹܐ ܡܵܫܸܟ̇ܢܵܐ ܚܵܐ."
		},
		{
			"verseNumberEn": "7",
			"verseNumberAs": "ܙ",
			"verseText": "ܘܬܵܪܨܸܬ ܦܲܪ̈ܕܹܐ (ܕܣܲܥܪܵܐ) ܕܥܸܙܹ̈ܐ ܩܵܐ ܟ̰ܼܿܕܪܵܐ ܥܲܠ ܡܵܫܸܟ̇ܢܵܐ: ܚܲܕܸܥܣܲܪ ܦܲܪ̈ܕܹܐ ܬܵܪܨܸܬ ܠܗ݇ܘܿܢ."
		},
		{
			"verseNumberEn": "8",
			"verseNumberAs": "ܚ",
			"verseText": "ܝܘܼܪܟ̣ܘܼܬܵܐ ܕܚܵܐ ܦܲܪܕܵܐ ܬܠܵܝܝܼ ܝܲܡܝܼ̈ܢܹܐ: ܘܦܸܬܝܘܼܬܵܐ ܐܲܪܒܲܥ ܝܲܡܝܼܢܹ̈ܐ ܕܚܵܐ ܦܲܪܕܵܐ: ܚܵܐ ܟܝܼܘܼܠܵܐ ܠܚܲܕܸܥܣܲܪ ܦܲܪ̈ܕܹܐ."
		},
		{
			"verseNumberEn": "9",
			"verseNumberAs": "ܛ",
			"verseText": "ܘܬܵܪܩܸܬ ܚܲܡܫܵܐ ܦܲܪ̈ܕܹܐ ܒܢܲܦ̮ܫܵܝ: ܘܐܸܫܬܵܐ ܦܲܪ̈ܕܹܐ ܒܢܲܦ̮ܫܵܝ: ܘܟܵܦܠܸܬ ܦܲܪܕܵܐ ܕܐܸܫܬܵܐ ܠܵܩܵܡ ܦܵܬܵܐ ܕܟ̰ܼܿܕܪܵܐ."
		},
		{
			"verseNumberEn": "10",
			"verseNumberAs": "ܝ",
			"verseText": "ܘܬܵܪܨܸܬ ܚܲܡܫܝܼ ܒܸܠܘܼܩܝܵܬܹ̈ܐ ܥܲܠ ܣܸܦܬܵܐ ܕܚܵܐ ܦܲܪܕܵܐ ܕܡܲܪܙܵܐ ܒܬܪܵܩܬܵܐ: ܘܚܲܡܫܝܼ ܒܸܠܘܼܩܝܵܬܹ̈ܐ ܥܲܠ ܣܸܦܬܵܐ ܕܦܲܪܕܵܐ ܕܬܪܵܩܬܵܐ ܕܗ̇ܘ ܕܬܪܵܝ."
		},
