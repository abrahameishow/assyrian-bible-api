{
	"chapterEn": "Chapter 21",
	"chapterAs": "ܩܦܠܐܘܢ: ܟܐ.",
	"verses": [
		{
			"verseNumberEn": "1",
			"verseNumberAs": "ܐ",
			"verseText": "ܘܐܲܢܹܐ ܝ݇ܢܵܐ ܫܲܪ̈ܥܲܬܹܐ ܕܡܲܬܒܸܬ ܩܵܡܝ."
		},
		{
			"verseNumberEn": "2",
			"verseNumberAs": "ܒ",
			"verseText": "ܟܲܕ ܙܵܒ̣ܢܸܬ ܪܹܓܵܐ ܥܸܒ̣ܪܵܝܵܐ: ܐܸܫܬܵܐ ܫܸܢܹ̈ܐ ܦܵܠܸܚ: ܘܒܗ̇ܝ ܕܫܲܒܲܥ ܦܵܠܸܛ ܐܵܙܵܕ ܚܘܼܪܵܝܝܼ."
		},
		{
			"verseNumberEn": "3",
			"verseNumberAs": "ܓ",
			"verseText": "ܐܸ‍ܢ ܒܢܲܦ̮ܫܘܼܗܝ ܐܵܬܹܐ: ܒܢܲܦ̮ܫܘܼܗܝ ܦܵܠܸܛ. ܐܸ‍ܢ ܡܵܪܹܐ ܒܲܟ̣ܬܵܐ ܝ݇ܠܹܐ: ܦܵܠܛܵܐ ܒܲܟ̣ܬܘܼܗܝ ܥܲܡܹܗ."
		},
		{
			"verseNumberEn": "4",
			"verseNumberAs": "ܕ",
			"verseText": "ܐܸ‍ܢ ܐܵܓ̣ܵܝܘܼܗܝ ܝܵܗ݇ܒܸܠ ܠܹܗ̇ ܒܲܟ̣ܬܵܐ: ܘܝܵܠܕܵܐ ܩܵܬܹܗ ܒܢܘܼܢܹ̈ܐ ܝܲܢ ܒܢܵܬܹ̈ܐ: ܒܲܟ̣ܬܵܐ ܘܝܵܠܘܼ̈ܗ̇ ܗܵܘܝܵܐ ܠܐܵܓ̣ܵܝܘܼܗ̇: ܘܗ̇ܘ ܦܵܠܸܛ ܒܢܲܦ̮ܫܘܼܗܝ."
		},
