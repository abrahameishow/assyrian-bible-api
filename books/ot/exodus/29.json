{
	"chapterEn": "Chapter 29",
	"chapterAs": "ܩܦܠܐܘܢ: ܟܛ.",
	"verses": [
		{
			"verseNumberEn": "1",
			"verseNumberAs": "ܐ",
			"verseText": "ܘܐܵܗܵܐ ܝ݇ܠܹܐ ܡܸܢܕܝܼ ܕܥܵܒ̣ܕܸܬ ܐܸܠܵܝ: ܠܩܵܕܘܿܫܵܝ: ܠܸܥܒ̣ܵܕܵܐ ܟܵܗܢܘܼܬܵܐ ܐܸܠܝܼ: ܫܩܘܿܠ ܚܵܐ ܡܘܼܓ̰ܵܐ ܒܲܪ ܒܲܩܪܵܐ: ܘܬܪܵܝ ܒܲܪ̈ܥܵܢܹܐ ܕܠܵܐ ܠܲܟܵܐ:"
		},
		{
			"verseNumberEn": "2",
			"verseNumberAs": "ܒ",
			"verseText": "ܘܠܲܚܡܵܐ ܦܲܛܝܼܪܵܐ ܘܟܵܕܹ̈ܐ ܦܲܛܝܼܪܹ̈ܐ ܓܒ̣ܝܼܠܹܐ ܒܡܸܫܚܵܐ: ܘܪ̈ܵܩܝܼܩܹܐ ܦܲܛܝܼܪܹ̈ܐ ܡܫܝܼܚܹܐ ܒܡܸܫܚܵܐ: ܢܫܝܼܦܵܐ ܕܚܸܛܹ̈ܐ ܬܵܪܨܸܬ ܠܗ݇ܘܿܢ."
		},
		{
			"verseNumberEn": "3",
			"verseNumberAs": "ܓ",
			"verseText": "ܘܡܲܬܒܸܬ ܠܗ݇ܘܿܢ ܒܚܵܐ ܣܵܠܵܐ: ܘܡܲܐܝܸܬ ܠܗ݇ܘܿܢ ܒܣܵܠܵܐ: ܘܡܘܼܓ̰ܵܐ ܘܬܸܪܘܵܝ ܒܲܪ̈ܥܵܢܹܐ."
		},
		{
			"verseNumberEn": "4",
			"verseNumberAs": "ܕ",
			"verseText": "ܘܠܲܐܗܪܘܿܢ ܘܠܒܢܘܼܢ̈ܘܼܗܝ ܡܲܐܝܸܬ ܠܬܲܪܥܵܐ ܕܡܲܫܟܲܢ ܘܲܥܕܵܐ: ܘܡܲܣܚܸܬ ܠܗ݇ܘܿܢ ܒܡ̈ܝܼܵܐ."
		},
		{
			"verseNumberEn": "5",
			"verseNumberAs": "ܗ",
			"verseText": "ܘܫܵܩܠܸܬ ܠܠܒ̣ܘܼܫܹ̈ܐ ܘܡܲܠܒܸܫܸܬ ܠܐܲܗܪܘܿܢ ܨܘܼܕܪܵܐ: ܘܩܒ̣ܵܝܬܵܐ ܕܐܸܦܘܿܕܵܐ: ܘܐܸܦܘܿܕܵܐ ܘܒܪܵܬ݇ ܨܲܕܪܵܐ: ܘܐܵܣܪܸܬ ܠܹܗ ܒܙܘܼܢܵܪܵܐ ܕܐܸܦܘܿܕܵܐ."
		},
		{
			"verseNumberEn": "6",
			"verseNumberAs": "ܘ",
			"verseText": "ܘܡܲܬܒܸܬ ܟܪܵܟ̣ܬܵܐ ܥܲܠ ܪܹܫܘܼܗܝ: ܘܡܲܬܒܸܬ ܟܠܝܼܠܵܐ ܕܩܘܼܕܫܵܐ ܥܲܠ ܟܪܵܟ̣ܬܵܐ."
		},
		{
			"verseNumberEn": "7",
			"verseNumberAs": "ܙ",
			"verseText": "ܘܫܵܩܠܸܬ ܡܸܫܚܵܐ ܕܡܫܵܚܬܵܐ: ܘܨܲܢܨܸܠܸܬ ܥܲܠ ܪܹܫܘܼܗܝ: ܘܡܵܫܚܸܬ ܠܹܗ."
		},
		{
			"verseNumberEn": "8",
			"verseNumberAs": "ܚ",
			"verseText": "ܘܠܒܢܘܼܢ̈ܘܼܗܝ ܡܲܐܝܸܬ ܘܡܲܠܒܸܫܸܬ ܠܗ݇ܘܿܢ ܨܘܼܕܪܵ̈ܬܹܐ."
		},
		{
			"verseNumberEn": "9",
			"verseNumberAs": "ܛ",
			"verseText": "ܘܚܵܠܨܸܬ ܠܗ݇ܘܿܢ ܒܚܘܼܪܵܪܵܐ: ܐܲܗܪܘܿܢ ܘܒܢܘܼܢ̈ܘܼܗܝ: ܘܐܵܣܪܸܬ ܥܲܠܵܝ ܫܲܡܠܹ̈ܐ: ܘܗܵܘܝܵܐ ܐܸܠܵܝ ܟܲܗܢܘܼܬܵܐ ܠܩܵܢܘܿܢܵܐ ܕܥܵܠܲܡ: ܘܣܵܝܡܸܬ ܠܐܲܗܪܘܿܢ ܘܠܒܢ̈ܘܼܢܘܼܗܝ."
		},
		{
			"verseNumberEn": "10",
			"verseNumberAs": "ܝ",
			"verseText": "ܘܡܲܐܝܸܬ ܠܡܘܼܓ̰ܵܐ ܠܵܩܵܡ ܡܲܫܟܲܢ ܘܲܥܕܵܐ: ܘܡܲܬܒ̣ܝܼ ܐܲܗܪܘܿܢ ܘܒܢܘܼܢ̈ܘܼܗܝ ܐܝܼܕܵܬܵܝ̈ ܥܲܠ ܪܹܫܹܗ ܕܡܘܼܓ̰ܵܐ."
		},
		{
			"verseNumberEn": "11",
			"verseNumberAs": "ܝܐ",
			"verseText": "ܘܦܵܪܡܸܬ ܠܡܘܼܓ̰ܵܐ ܩܵܡ ܡܵܪܝܵܐ: ܒܬܲܪܥܵܐ ܕܡܲܫܟܲܢ ܘܲܥܕܵܐ."
		},
		{
