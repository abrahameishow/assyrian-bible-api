{
	"chapterEn": "Chapter 6",
	"chapterAs": "ܩܦܠܐܘܢ: ܘ.",
	"verses": [
		{
			"verseNumberEn": "1",
			"verseNumberAs": "ܐ",
			"verseText": "ܘܐ݇ܡܸܪܹܐ ܡܵܪܝܵܐ ܠܡܘܼܫܹܐ: ܐܵܕܝܼܵܐ ܒܸܬ ܚܵܙܸܬ ܡܸܢܕܝܼ ܕܥܵܒ̣ܕܸ‍ܢ ܠܦܸܪܥܘܿܢ: ܣܵܒܵܒ̇ ܕܒܐܝܼܕܵܐ ܙܲܪܒܵܢܬܵܐ ܒܸܬ ܫܵܕܸܪܘܿܢ: ܘܒܐܝܼܕܵܐ ܙܲܪܒܵܢܬܵܐ ܒܸܬ ܛܵܪܸܕܠܘܿܢ ܡ̣ܢ ܐܲܪܥܘܼܗܝ."
		},
		{
			"verseNumberEn": "2",
			"verseNumberAs": "ܒ",
			"verseText": "ܘܗܘܼܡܙܸܡܠܹܐ ܐܲܠܵܗܵܐ ܥܲܡ ܡܘܼܫܹܐ: ܘܐ݇ܡܸܪܹܐ ܐܸܠܹܗ: ܐܵܢܵܐ ܝ݇ܘܸ‍ܢ ܝܹܗܘܿܘܵܐ:"
		},
		{
			"verseNumberEn": "3",
			"verseNumberAs": "ܓ",
			"verseText": "ܘܦܸܫܠܝܼ ܚܸܙܝܵܐ ܠܐܲܒ̣ܪܵܗܵܡ: ܠܐܝܼܣܚܵܩ: ܘܠܝܲܥܩܘܿܒ̣: ܒܐܹܝܠܫܲܕܲܝ: ܘܒܫܸܡܝܼ ܝܹܗܘܿܘܵܐ ܠܵܐ ܦܸܫܠܝܼ ܡܘܼܕܸܥܝܵܐ ܐܸܠܵܝ."
		},
		{
			"verseNumberEn": "4",
			"verseNumberAs": "ܕ",
			"verseText": "ܘܐܘܼܦ ܡܘܼܩܸܡܠܝܼ ܠܩܵܘܠܝܼ ܥܲܡܵܝ: ܠܝܼܵܗ݇ܒ̣ܵܐ ܐܸܠܵܝ ܐܲܪܥܵܐ ܕܟܢܲܥܢ: ܐܲܪܥܵܐ ܕܡܵܫܵܚܲܛܘܼܬܵܝ: ܕܡܘܼܫܚܸܛܠܘܿܢ ܓܵܘܘܼܗ̇."
		},
